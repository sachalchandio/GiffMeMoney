# =============================================================================
# GiffMeMoney — example environment file.
#
#   cp .env.example .env      then edit as needed.
#
# EVERY variable here has a SAFE default already baked into the app
# (backend/app/config.py), so an EMPTY .env runs the full default path:
#   simulated market data · simulated (paper) broker · in-memory storage.
# Nothing below needs to be set to run the app. Each variable is documented;
# the live-trading ones carry explicit WARNINGS.
#
# Env var names map 1:1 (case-insensitively) to the settings fields — there is
# NO prefix. e.g. PROVIDER -> settings.provider, BROKER_ACK -> settings.broker_ack.
# CORS_ORIGINS accepts a bare comma-separated list (a,b,c) or a JSON array.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. MARKET DATA PROVIDER  (read-only; no trading capability in the data layer)
# -----------------------------------------------------------------------------
# Which market-data backend feeds prices/candles/analysis.
#   simulated  -> built-in deterministic simulator (DEFAULT; no network, no keys)
#   finnhub    -> real equities + fundamentals (needs FINNHUB_API_KEY)
#   polygon    -> real equities / aggregates    (needs POLYGON_API_KEY)
#   coingecko  -> real crypto                    (COINGECKO_API_KEY optional)
#   binance    -> real crypto                    (BINANCE_API_KEY optional)
# Any real provider falls back to the simulator for a symbol/series it can't
# serve, and falls back entirely to simulated if its key is missing or a call
# fails — the app never crashes on a bad/absent key.
PROVIDER=simulated

# Provider API keys (only the one matching PROVIDER above is used). Free tiers
# exist for Finnhub and CoinGecko — see docs/DEPLOY.md for sign-up links.
FINNHUB_API_KEY=
POLYGON_API_KEY=
COINGECKO_API_KEY=
BINANCE_API_KEY=


# -----------------------------------------------------------------------------
# 2. BROKER EXECUTION  (OPT-IN; ships in the SAFE simulated/paper mode)
# -----------------------------------------------------------------------------
# Which broker executes orders placed via /api/broker.
#   simulated  -> paper fills at the market provider price; NO real money (DEFAULT)
#   alpaca     -> Alpaca REST adapter; defaults to Alpaca's PAPER (sandbox) host,
#                 so even WITH keys set, no real money moves unless the full
#                 live hard-gate (section 2b) is satisfied.
BROKER=simulated

# Alpaca credentials. For PAPER trading, generate *paper* keys in the Alpaca
# dashboard (Paper Trading). These are required when BROKER=alpaca.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Alpaca REST base URL. DEFAULTS to the PAPER (sandbox) endpoint — leave it as-is
# for paper trading. The live host is shown (commented) in section 2b only.
ALPACA_BASE_URL=https://paper-api.alpaca.markets


# -----------------------------------------------------------------------------
# 2b. ⚠  REAL-MONEY LIVE TRADING GATES  —  AT YOUR OWN RISK  ⚠
# -----------------------------------------------------------------------------
# DO NOT SET THESE unless you have read the "ENABLING REAL TRADING" section of
# docs/DEPLOY.md in full and accept that REAL ORDERS WITH REAL MONEY may be
# placed and you may LOSE MONEY. Real trading is a DELIBERATE action — there is
# intentionally no UI button for it. Live is OFF by default and stays OFF unless
# ALL of the following hold together:
#   1) BROKER=alpaca
#   2) ALPACA_LIVE=1
#   3) ALPACA_BASE_URL=https://api.alpaca.markets   (the LIVE host)
#   4) real ALPACA_API_KEY + ALPACA_SECRET_KEY (your LIVE keys)
#   5) BROKER_ACK set to the EXACT phrase below
# Even then, each order must also repeat the exact acknowledgement phrase.
# Recommendation: run for WEEKS on paper first (BROKER=alpaca, paper host) and
# validate behaviour before considering any of this.
#
# Master live flag. 0/false = paper (DEFAULT). 1/true = arm live (with the rest).
ALPACA_LIVE=0
#
# Exact live-trading acknowledgement. Live orders are refused unless this string
# matches EXACTLY (character-for-character). Leave EMPTY to keep live disabled.
#   BROKER_ACK=I understand this places real orders
BROKER_ACK=


# -----------------------------------------------------------------------------
# 3. PERSISTENCE  (OPT-IN; ships in-memory)
# -----------------------------------------------------------------------------
# Where users/accounts/positions are stored.
#   memory  -> in-process; reset on restart (DEFAULT; what the tests use)
#   sqlite  -> a NEW SQLite file (created on first use; an existing DB is never
#              touched — no drop/alter/migrate beyond first create_all)
PERSIST=memory

# SQLAlchemy URL used only when PERSIST=sqlite.
#   Local (run.py)        : sqlite:///giffmemoney.db    (in backend/ working dir)
#   Docker compose        : sqlite:///data/giffmemoney.db
#       -> the compose file maps ./data on the host to /app/data in the
#          container, so the DB survives container restarts. If you keep the
#          default below under Docker, the DB lives inside the container and is
#          lost when it is removed.
DB_URL=sqlite:///giffmemoney.db


# -----------------------------------------------------------------------------
# 4. AUTH / SECURITY
# -----------------------------------------------------------------------------
# HMAC signing secret for auth JWTs. The default is a DEV secret — CHANGE THIS
# to a long random string in any real deployment (e.g. `openssl rand -hex 32`).
JWT_SECRET=dev-secret-change-me

# Auth token lifetime, in days.
JWT_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# 5. CORS  (which browser origins may call the API)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Include wherever the frontend is
# served from. For the docker-compose default the SPA is at http://localhost:8080.
# Defaults (when unset) cover the Vite dev server on 5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080


# -----------------------------------------------------------------------------
# 6. MISC RUNTIME TUNABLES (optional; sensible defaults shown)
# -----------------------------------------------------------------------------
# Annual risk-free rate (decimal) used by the quant engine. e.g. 0.04 = 4%.
# RISK_FREE_RATE=0.04
# Interval between live WebSocket price ticks, in milliseconds.
# TICK_INTERVAL_MS=1000


# =============================================================================
# 7. FRONTEND BUILD ARG (NOT a backend env var)
# =============================================================================
# VITE_API_URL is inlined into the SPA bundle AT BUILD TIME (Vite reads
# import.meta.env.* during `vite build`), so it is consumed as a build-arg by
# the frontend image / compose `frontend.build.args`, not by the backend.
# Point it at wherever the BROWSER can reach the backend:
#   http://localhost:8000  -> browser calls the backend directly (compose default)
#   (empty string)         -> browser calls /api + /ws on the frontend origin,
#                             which nginx proxies to the backend (single-origin)
VITE_API_URL=http://localhost:8000
